{
  "name": "booking-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "npm -w @booking/frontend run lint && npm -w @booking/backend run lint",
    "format": "prettier --write .",
